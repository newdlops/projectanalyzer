{
  "name": "project-analyzer",
  "displayName": "Project Analyzer",
  "description": "Evidence-ranked project guided tours with architectural layers and source-backed exploration.",
  "version": "0.0.1007",
  "publisher": "local",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onView:projectAnalyzer.explorerView"
  ],
  "main": "./out/extension/activate.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "projectAnalyzer",
          "title": "Project Analyzer",
          "icon": "media/project-analyzer.svg"
        }
      ]
    },
    "views": {
      "projectAnalyzer": [
        {
          "id": "projectAnalyzer.explorerView",
          "name": "Project Guide",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Project Analyzer",
      "properties": {
        "projectAnalyzer.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Project Analyzer extension features."
        },
        "projectAnalyzer.autoAnalyze": {
          "type": "boolean",
          "default": true,
          "description": "Analyze the workspace automatically when the explorer opens."
        },
        "projectAnalyzer.include": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/*.{ts,tsx,js,jsx,py}"
          ],
          "description": "Glob patterns included in project analysis."
        },
        "projectAnalyzer.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/node_modules/**",
            "**/.git/**",
            "**/dist/**",
            "**/build/**",
            "**/out/**",
            "**/target/**",
            "**/coverage/**",
            "**/.venv/**",
            "**/venv/**"
          ],
          "description": "Glob patterns excluded from project analysis."
        },
        "projectAnalyzer.maxFileSizeKb": {
          "type": "number",
          "default": 1024,
          "minimum": 1,
          "description": "Maximum source file size in KiB for static analysis."
        },
        "projectAnalyzer.maxRenderedNodes": {
          "type": "number",
          "default": 500,
          "minimum": 1,
          "description": "Maximum graph nodes rendered in a single explorer view."
        },
        "projectAnalyzer.defaultDepth": {
          "type": "number",
          "default": 2,
          "minimum": 0,
          "description": "Default graph expansion depth for caller and callee exploration."
        },
        "projectAnalyzer.includeExternalDependencies": {
          "type": "boolean",
          "default": false,
          "description": "Include external dependency nodes in graph views."
        },
        "projectAnalyzer.showUnresolvedEdges": {
          "type": "boolean",
          "default": true,
          "description": "Show graph edges whose target cannot be resolved statically."
        },
        "projectAnalyzer.cache.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Persist analysis cache in VS Code workspace storage."
        },
        "projectAnalyzer.cache.maxSizeMb": {
          "type": "number",
          "default": 256,
          "minimum": 1,
          "description": "Maximum persisted analysis cache size in MiB."
        }
      }
    }
  },
  "dependencies": {
    "typescript": "^5.8.3"
  },
  "scripts": {
    "engine:build": "cargo build --manifest-path engine/analyzer/Cargo.toml",
    "engine:build:release": "cargo build --release --manifest-path engine/analyzer/Cargo.toml",
    "engine:stage": "node scripts/stage-runtime-engine.mjs",
    "engine:test": "cargo test --manifest-path engine/analyzer/Cargo.toml",
    "dev:prepare": "npm run engine:build && npm run compile",
    "compile": "node scripts/clean-output.mjs && tsc -p ./tsconfig.json",
    "watch": "tsc -watch -p ./tsconfig.json",
    "check": "tsc -p ./tsconfig.json --noEmit",
    "test:package": "node --test scripts/check-vsix-package.test.mjs",
    "test": "npm run engine:test && npm run compile && node --test out/test/unit/*.test.js && npm run test:package",
    "package:check": "node scripts/check-vsix-package.mjs",
    "package:vsix": "node scripts/package-extension.mjs",
    "vscode:prepublish": "npm run engine:build:release && npm run engine:stage && npm run compile"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/vscode": "^1.92.0"
  }
}
