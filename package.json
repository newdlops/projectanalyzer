{
  "name": "project-analyzer",
  "displayName": "Project Analyzer: Code Flow",
  "description": "Understand unfamiliar codebases through bounded, source-backed code flows.",
  "version": "0.0.1037",
  "publisher": "newdlops",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/newdlops/projectanalyzer.git"
  },
  "homepage": "https://github.com/newdlops/projectanalyzer#readme",
  "bugs": {
    "url": "https://github.com/newdlops/projectanalyzer/issues"
  },
  "icon": "media/project-analyzer-icon.png",
  "preview": true,
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "code flow",
    "code visualization",
    "control flow",
    "call graph",
    "static analysis",
    "codebase navigation",
    "typescript",
    "python",
    "java",
    "functional programming"
  ],
  "galleryBanner": {
    "color": "#111B3C",
    "theme": "dark"
  },
  "activationEvents": [
    "onView:projectAnalyzer.explorerView",
    "onCommand:projectAnalyzer.visualizeCurrentFunction",
    "onCommand:projectAnalyzer.openModuleFlow"
  ],
  "main": "./out/extension/activate.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "projectAnalyzer",
          "title": "Code Flow",
          "icon": "media/project-analyzer.svg"
        }
      ]
    },
    "views": {
      "projectAnalyzer": [
        {
          "id": "projectAnalyzer.explorerView",
          "name": "Understand Code",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "projectAnalyzer.visualizeCurrentFunction",
        "title": "Visualize Current Function",
        "category": "Code Flow"
      },
      {
        "command": "projectAnalyzer.openModuleFlow",
        "title": "Open Project Module Flow",
        "category": "Code Flow",
        "icon": "$(type-hierarchy)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "projectAnalyzer.visualizeCurrentFunction",
          "when": "editorLangId =~ /^(typescript|typescriptreact|javascript|javascriptreact|python|java|fsharp|ocaml|elixir)$/",
          "group": "navigation@100"
        }
      ],
      "view/title": [
        {
          "command": "projectAnalyzer.openModuleFlow",
          "when": "view == projectAnalyzer.explorerView",
          "group": "navigation@90"
        }
      ]
    },
    "configuration": {
      "title": "Project Analyzer: Code Flow",
      "properties": {
        "projectAnalyzer.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Project Analyzer extension features."
        },
        "projectAnalyzer.autoAnalyze": {
          "type": "boolean",
          "default": true,
          "description": "Analyze the workspace automatically so Code Flow starting points are ready when the view opens."
        },
        "projectAnalyzer.include": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/*.{ts,tsx,js,jsx,py,java,fs,fsx,ml,mli,ex,exs}"
          ],
          "description": "Glob patterns included in project analysis."
        },
        "projectAnalyzer.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/node_modules/**",
            "**/.git/**",
            "**/dist/**",
            "**/build/**",
            "**/out/**",
            "**/target/**",
            "**/coverage/**",
            "**/.venv/**",
            "**/venv/**"
          ],
          "description": "Glob patterns excluded from project analysis."
        },
        "projectAnalyzer.maxFileSizeKb": {
          "type": "number",
          "default": 1024,
          "minimum": 1,
          "description": "Maximum source file size in KiB for static analysis."
        },
        "projectAnalyzer.maxRenderedNodes": {
          "type": "number",
          "default": 500,
          "minimum": 1,
          "description": "Maximum graph nodes rendered in a single explorer view."
        },
        "projectAnalyzer.defaultDepth": {
          "type": "number",
          "default": 2,
          "minimum": 0,
          "description": "Default graph expansion depth for caller and callee exploration."
        },
        "projectAnalyzer.codeFlow.maxDepth": {
          "type": "number",
          "default": 3,
          "minimum": 0,
          "maximum": 12,
          "description": "Maximum downstream call depth shown for a selected-function Code Flow."
        },
        "projectAnalyzer.codeFlow.maxSteps": {
          "type": "number",
          "default": 30,
          "minimum": 1,
          "maximum": 200,
          "description": "Maximum visible steps in a selected-function Code Flow."
        },
        "projectAnalyzer.codeFlow.maxLogicBlocks": {
          "type": "number",
          "default": 120,
          "minimum": 1,
          "maximum": 300,
          "description": "Maximum syntax-backed statement and expression blocks in a selected Function Logic flow."
        },
        "projectAnalyzer.includeExternalDependencies": {
          "type": "boolean",
          "default": false,
          "description": "Include external dependency nodes in graph views."
        },
        "projectAnalyzer.showUnresolvedEdges": {
          "type": "boolean",
          "default": true,
          "description": "Show graph edges whose target cannot be resolved statically."
        },
        "projectAnalyzer.cache.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Persist analysis cache in VS Code workspace storage."
        },
        "projectAnalyzer.cache.maxSizeMb": {
          "type": "number",
          "default": 256,
          "minimum": 1,
          "description": "Maximum persisted analysis cache size in MiB."
        }
      }
    }
  },
  "dependencies": {
    "@lezer/java": "^1.1.3",
    "@lezer/python": "^1.1.19",
    "typescript": "^5.8.3"
  },
  "scripts": {
    "engine:build": "cargo build --manifest-path engine/analyzer/Cargo.toml",
    "engine:build:release": "cargo build --release --manifest-path engine/analyzer/Cargo.toml",
    "engine:stage": "node scripts/stage-runtime-engine.mjs",
    "engine:test": "cargo test --manifest-path engine/analyzer/Cargo.toml",
    "dev:prepare": "npm run engine:build && npm run compile",
    "compile": "node scripts/clean-output.mjs && tsc -p ./tsconfig.json",
    "watch": "tsc -watch -p ./tsconfig.json",
    "check": "tsc -p ./tsconfig.json --noEmit",
    "test:package": "node --test scripts/*.test.mjs",
    "test": "npm run engine:test && npm run compile && node --test out/test/unit/*.test.js && npm run test:package",
    "package:check": "node scripts/check-vsix-package.mjs",
    "package:vsix": "node scripts/package-extension.mjs",
    "release:check": "node scripts/check-release-metadata.mjs",
    "vscode:prepublish": "npm run engine:build:release && npm run engine:stage && npm run compile"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.2",
    "@types/node": "^22.15.30",
    "@types/vscode": "^1.92.0"
  }
}
