# Development and repository metadata
.gitignore
.github/**
.vscode/**
.vscode-test/**
.codex/**
.codeidx/**
.portmanager/**
.lh/**
.zoek-rs/**
.mcp.json
AGENTS.md
SPEC.MD
FunctionSpec.md
package-lock.json
tsconfig.json
*.log
log*.txt
*.zip
*.vsix

# TypeScript and Rust sources are compiled before VSIX packaging
src/**
scripts/**
engine/analyzer/src/**
engine/analyzer/target/**
engine/analyzer/Cargo.toml
engine/analyzer/Cargo.lock
out/test/**
out/**/*.map

# The fallback parser only needs TypeScript's self-contained runtime module.
node_modules/typescript/README.md
node_modules/typescript/SECURITY.md
node_modules/typescript/bin/**
node_modules/typescript/lib/**/*.d.ts
node_modules/typescript/lib/**/*.map
node_modules/typescript/lib/*/**
node_modules/typescript/lib/typesMap.json
node_modules/typescript/lib/_tsc.js
node_modules/typescript/lib/_tsserver.js
node_modules/typescript/lib/_typingsInstaller.js
node_modules/typescript/lib/tsc.js
node_modules/typescript/lib/tsserver.js
node_modules/typescript/lib/tsserverlibrary.js
node_modules/typescript/lib/typingsInstaller.js
node_modules/typescript/lib/watchGuard.js

# Python/Java Lezer adapters need only CommonJS runtime modules and manifests.
node_modules/@lezer/**/README.md
node_modules/@lezer/**/CHANGELOG.md
node_modules/@lezer/**/rollup.config.js
node_modules/@lezer/**/src/**
node_modules/@lezer/**/test/**
node_modules/@lezer/**/dist/*.js
node_modules/@lezer/**/dist/*.d.ts
node_modules/@lezer/**/dist/*.d.cts
